###############################################
# Frontend .env.local example (apps/web/.env.local)
# Copy values from root .env.example
###############################################

# Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key (never use service role key here)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# App display name
NEXT_PUBLIC_APP_NAME=Nous

# Optional: Edge Functions base URL after deploy
# NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.functions.supabase.co

