###############################################
# Backend .env example (apps/api/.env)
# Copy values from root .env.example
###############################################

API_PORT=4000
API_HOST=0.0.0.0

# Supabase project URL (Project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key (SECRET - never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Public anon key (safe for frontend, also used here for auth flows)
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

