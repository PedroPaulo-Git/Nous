############################################################
# Notisafe Monorepo Environment Example (Single Source of Truth)
#
# Copy this file to two places and rename:
#   1) apps/api/.env          -> for backend only (never commit real secrets)
#   2) apps/web/.env.local    -> for frontend only
#
# Why split? The backend needs SERVICE_ROLE key (secret). The frontend must
# NEVER include the service role key (only anon + public URLs).
#
# If you prefer a single source, keep this file updated and copy values into
# each app manually. Do NOT load backend secrets into the frontend.
#
# IMPORTANT: Replace placeholders with your real project values from
# Supabase Dashboard -> Project Settings -> API.
############################################################

########################
# Shared project values
########################
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"          # e.g. https://abcdxyzsupabaseid.supabase.co
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"                  # Public anon key (safe for frontend)

########################
# Backend only (apps/api/.env)
########################
API_PORT=4000
API_HOST=0.0.0.0
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"  # Found in Project Settings -> API (keep secret)

########################
# Frontend only (apps/web/.env.local)
########################
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"  # Must match SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"           # Same anon key
NEXT_PUBLIC_API_URL="http://localhost:4000"                      # Backend base URL
NEXT_PUBLIC_APP_NAME="Notisafe"

# Optional: Edge Functions base URL (set after deploy)
# NEXT_PUBLIC_SUPABASE_FUNCTIONS_URL="https://YOUR_PROJECT_REF.functions.supabase.co"

# DO NOT PLACE SERVICE ROLE KEY IN FRONTEND .env.local

############################################################
# How to obtain keys:
# 1. Login to Supabase Dashboard
# 2. Go to Project Settings -> API
# 3. Copy:
#    - Project URL -> SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
#    - anon public key -> SUPABASE_ANON_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role secret key -> SUPABASE_SERVICE_ROLE_KEY (backend only)
############################################################

